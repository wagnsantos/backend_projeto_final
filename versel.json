{
    "version": 2,
    "builds": [
      {
        "src": "src/server.ts",
        "use": "@vercel/node",
        "config": {
          "maxDuration": 10
        }
      }
    ],
    "env": {
      "DATABASE_URL": "@database_url"
    },
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/src/server.ts"
      }
    ]
  }
  